# ============================================================
# ContractIQ — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================


# ============================================================
# Supabase
# Get these from: Supabase Dashboard → Settings → API
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=           # Your Supabase project URL (e.g. https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Supabase anon/public key — safe to expose to browser

SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY — Supabase service role key (bypasses RLS)
                                    # Used in API routes for elevated DB operations
                                    # Never expose to the client / never use NEXT_PUBLIC_ prefix


# ============================================================
# OpenAI
# Get this from: platform.openai.com → API Keys
# ============================================================

OPENAI_API_KEY=                     # SERVER ONLY — OpenAI secret key
                                    # Used for GPT-4o extraction and chat calls
                                    # Never expose to the client


# ============================================================
# Rate Limiting (Upstash Redis)
# Get these from: console.upstash.com → Redis → REST API
# Required for /api/process and /api/chat rate limiting.
# If not using Upstash, replace with in-memory fallback (dev only).
# ============================================================

UPSTASH_REDIS_REST_URL=             # SERVER ONLY — Upstash Redis REST endpoint
UPSTASH_REDIS_REST_TOKEN=           # SERVER ONLY — Upstash Redis REST token


# ============================================================
# App Configuration
# ============================================================

NEXT_PUBLIC_APP_URL=                # Full URL of the deployed app (e.g. https://contractiq.com)
                                    # Used for auth callback redirects and email links

NODE_ENV=development                # 'development' | 'production' | 'test'

MAX_CHAT_HISTORY=100                # Max chat messages sent to the model per request (default: 100)
